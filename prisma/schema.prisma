generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Conversation {
  id        String    @id @default(cuid())
  title     String
  agentId   String
  model     String
  provider  String
  favorite  Boolean   @default(false)
  tags      String    @default("[]")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([agentId])
  @@index([updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  tokenEstimate  Int          @default(0)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model MemoryItem {
  id        String   @id @default(cuid())
  type      String
  title     String
  content   String
  source    String?
  tags      String   @default("[]")
  favorite  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([updatedAt])
}

model AutomationRun {
  id        String   @id @default(cuid())
  type      String
  status    String
  payload   String
  createdAt DateTime @default(now())
}
